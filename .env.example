# BiBooks 服务器环境变量
# 复制为 .env 后修改

# ========== 数据库 ==========
# sqlite 或 postgres
DB_MODE=postgres
DB_NAME=bibooks
DB_USER=bibooks
DB_PASSWORD=bibooks

# ========== API ==========
# 可选：设置 API 密钥保护接口
# API_KEY=my-secret-key-2026
API_KEY=

# ========== Ollama 本地模型 ==========
# 本地模型 Base URL（Docker 内用服务名）
OLLAMA_BASE_URL=http://ollama:11434
# 要拉取的模型名称
OLLAMA_MODEL_NAME=qwen2.5:7b
# 文本模型选择
TEXT_MODEL_PROVIDER=ollama
TEXT_MODEL_NAME=qwen2.5:7b
# API Key（Ollama 不需要，云端 API 需要）
TEXT_MODEL_API_KEY=

# ========== 端口 ==========
# 应用端口
APP_PORT=9800
# Ollama 端口
OLLAMA_PORT=11434
# Nginx 前端端口
NGINX_PORT=80
